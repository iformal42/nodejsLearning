
extends baseEmail 
block content 
  p Hi #{firstName},
  p forgot your password? Submit a request with your new password to: #{url}.
  p (Website for this action is not implemented.)
  table.btn.btn-primary(role='presentation', border='0', cellpadding='0', cellspacing='0')
    tbody
      tr
        td(align='left')
          table(role='presentation', border='0', cellpadding='0', cellspacing='0')
            tbody
              tr
                td
                  a(href=`${url}`, target='_blank') Reset your password
  p If you didn't forgot your password, please ignore this email.
  p - Musaif Bangi, CEO